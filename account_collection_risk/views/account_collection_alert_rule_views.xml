<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View Tree -->
    <record id="view_account_collection_alert_rule_tree" model="ir.ui.view">
        <field name="name">account.collection.alert.rule.tree</field>
        <field name="model">account.collection.alert.rule</field>
        <field name="arch" type="xml">
            <list string="Reglas de Riesgo de Cobro">
                <field name="name"/>
                <field name="days_overdue"/>
                <field name="amount_min"/>
                <field name="risk_level"/>
            </list>
        </field>
    </record>

    <!-- View Form -->
    <record id="view_account_collection_alert_rule_form" model="ir.ui.view">
        <field name="name">account.collection.alert.rule.form</field>
        <field name="model">account.collection.alert.rule</field>
        <field name="arch" type="xml">
            <form string="Regla de Riesgo">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej. Riesgo Alto (>30 días)"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="days_overdue"/>
                            <field name="amount_min"/>
                        </group>
                        <group>
                            <field name="risk_level"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_account_collection_alert_rule" model="ir.actions.act_window">
        <field name="name">Reglas de Riesgo de Cobro</field>
        <field name="res_model">account.collection.alert.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_account_collection_alert_rule"
              name="Reglas de Riesgo de Cobro"
              parent="account.menu_finance_configuration"
              action="action_account_collection_alert_rule"
              sequence="110"/>
</odoo>
