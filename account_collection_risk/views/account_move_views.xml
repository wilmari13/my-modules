<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extensión formulario de factura para mostrar riesgo -->
    <record id="view_move_form_inherit_collection_risk" model="ir.ui.view">
        <field name="name">account.move.form.inherit.collection.risk</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date_due']" position="after">
                <field name="x_risk_level" readonly="1" invisible="move_type not in ('out_invoice', 'out_receipt') or state != 'posted'"/>
            </xpath>
        </field>
    </record>

    <!-- Vista Kanban Tablero de Riesgo -->
    <record id="view_account_move_kanban_risk_dashboard" model="ir.ui.view">
        <field name="name">account.move.kanban.risk.dashboard</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <kanban default_group_by="x_risk_level" class="o_kanban_dashboard" create="false" edit="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount_residual"/>
                <field name="invoice_date_due"/>
                <field name="x_risk_level"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click border-start border-4 #{record.x_risk_level.raw_value == 'high' ? 'border-danger' : (record.x_risk_level.raw_value == 'medium' ? 'border-warning' : 'border-success')}">
                            <div style="padding-left: 15px;">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <!-- Bloque Izquierdo: Información del documento -->
                                    <div class="o_kanban_record_headings flex-grow-1" style="max-width: 70%;">
                                        <!-- Nombre del Partner/Cliente -->
                                        <strong class="o_kanban_record_title d-block mb-1 text-truncate" style="font-size: 1.05rem;">
                                            <field name="partner_id"/>
                                        </strong>
                                        
                                        <!-- Número de Factura -->
                                        <div class="text-muted small mb-1">
                                            <i class="fa fa-file-text-o me-1"/> <field name="name"/>
                                        </div>
                                        
                                        <!-- Fecha de Vencimiento -->
                                        <div class="small">
                                            <span t-attf-class="#{record.x_risk_level.raw_value == 'high' ? 'text-danger fw-bold' : 'text-muted'}">
                                                <i class="fa fa-calendar me-1"/> Vence: <field name="invoice_date_due"/>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Bloque Derecho: Monto destacado y grande -->
                                    <div class="text-end ps-2" style="max-width: 30%;">
                                        <strong class="d-block text-primary" style="font-size: 1.3rem; font-weight: 800; white-space: nowrap;">
                                            <field name="amount_residual" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Acción del Tablero -->
    <record id="action_account_move_risk_dashboard" model="ir.actions.act_window">
        <field name="name">Tablero de Riesgo de Cobro</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('move_type', 'in', ('out_invoice', 'out_receipt')), ('state', '=', 'posted'), ('payment_state', 'not in', ('paid', 'in_payment')), ('x_risk_level', '!=', 'none')]</field>
        <field name="view_id" ref="view_account_move_kanban_risk_dashboard"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Excelente! No tienes facturas con riesgo de atraso.
            </p>
        </field>
    </record>

    <!-- Menú del Tablero -->
    <menuitem id="menu_account_move_risk_dashboard"
              name="Tablero de Riesgo de Cobro"
              parent="account.menu_finance_receivables"
              action="action_account_move_risk_dashboard"
              sequence="20"/>
</odoo>
