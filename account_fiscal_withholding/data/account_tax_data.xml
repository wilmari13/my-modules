<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Grupo de Impuestos: IVA 16% -->
        <record id="tax_group_iva_16" model="account.tax.group">
            <field name="name">IVA 16%</field>
        </record>
        
        <!-- Grupo de Impuestos: Retención IVA -->
        <record id="tax_group_retencion_75" model="account.tax.group">
            <field name="name">Retención IVA</field>
        </record>

        <!-- Impuesto Principal: IVA 16% Ventas -->
        <record id="tax_iva_ventas_16" model="account.tax">
            <field name="name">IVA 16% (Ventas)</field>
            <field name="amount_type">percent</field>
            <field name="type_tax_use">sale</field>
            <field name="amount">16.0</field>
            <field name="description">IVA 16%</field>
            <field name="tax_group_id" ref="tax_group_iva_16"/>
            <field name="country_id" ref="base.ve"/> 
        </record>
        
        <!-- Impuesto Principal: IVA 16% Compras -->
        <record id="tax_iva_compras_16" model="account.tax">
            <field name="name">IVA 16% (Compras)</field>
            <field name="amount_type">percent</field>
            <field name="type_tax_use">purchase</field>
            <field name="amount">16.0</field>
            <field name="description">IVA 16%</field>
            <field name="tax_group_id" ref="tax_group_iva_16"/>
             <field name="country_id" ref="base.ve"/> 
        </record>

        <!-- Impuesto de Retención: 75% del IVA Ventas (-12% de la base) -->
        <record id="tax_retencion_iva_75_ventas" model="account.tax">
            <field name="name">Retención IVA 75% (Ventas)</field>
            <field name="amount_type">percent</field>
            <field name="type_tax_use">sale</field>
            <field name="amount">-12.0</field>
            <field name="description">Ret. IVA 75%</field>
            <field name="tax_group_id" ref="tax_group_retencion_75"/>
            <field name="country_id" ref="base.ve"/> 
        </record>

        <!-- Impuesto de Retención: 75% del IVA Compras (-12% de la base) -->
        <record id="tax_retencion_iva_75_compras" model="account.tax">
            <field name="name">Retención IVA 75% (Compras)</field>
            <field name="amount_type">percent</field>
            <field name="type_tax_use">purchase</field>
            <field name="amount">-12.0</field>
            <field name="description">Ret. IVA 75%</field>
            <field name="tax_group_id" ref="tax_group_retencion_75"/>
            <field name="country_id" ref="base.ve"/> 
        </record>
    </data>
</odoo>
