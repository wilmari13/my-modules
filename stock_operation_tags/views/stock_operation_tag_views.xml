<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista lista editable -->
    <record id="view_stock_operation_tag_list" model="ir.ui.view">
        <field name="name">stock.operation.tag.list</field>
        <field name="model">stock.operation.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="operation_type"/>
                <field name="description"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Vista formulario -->
    <record id="view_stock_operation_tag_form" model="ir.ui.view">
        <field name="name">stock.operation.tag.form</field>
        <field name="model">stock.operation.tag</field>
        <field name="arch" type="xml">
            <form string="Etiqueta Operativa">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="operation_type"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción de ventana -->
    <record id="action_stock_operation_tag" model="ir.actions.act_window">
        <field name="name">Etiquetas Operativas</field>
        <field name="res_model">stock.operation.tag</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primera etiqueta operativa.
            </p>
        </field>
    </record>

    <!-- Menú en Configuración de Inventario -->
    <menuitem id="menu_stock_operation_tag"
              name="Etiquetas Operativas"
              parent="stock.menu_stock_config_settings"
              action="action_stock_operation_tag"
              sequence="100"/>
</odoo>
