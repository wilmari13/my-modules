<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="product_template_form_view_inherit_stock_alert" model="ir.ui.view">
        <field name="name">product.template.form.inherit.stock.alert</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']//group[@name='operations']" position="after">
                <group string="Reglas de Reabastecimiento por Prioridad">
                    <field name="target_stock" string="Stock Objetivo"/>
                    <field name="replenishment_priority" string="Prioridad de Reabastecimiento"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_kanban_critical" model="ir.ui.view">
        <field name="name">product.template.kanban.critical</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <kanban default_group_by="replenishment_priority" class="o_kanban_small_column" create="false">
                <field name="qty_available"/>
                <field name="target_stock"/>
                <field name="replenishment_priority"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click d-flex flex-row align-items-center p-2 mb-1 shadow-sm border-start border-4 border-danger rounded-end bg-view">
                            
                            <div class="o_kanban_image me-3 flex-shrink-0 d-flex align-items-center justify-content-center bg-light rounded" style="width: 56px; height: 56px;">
                                <img t-att-src="'/web/image/product.template/' + record.id.raw_value + '/image_128'" 
                                    alt="Product" 
                                    class="img-fluid rounded"
                                    style="max-width: 100%; max-height: 100%; object-fit: contain;"/>
                            </div>
                            
                            <div class="oe_kanban_details d-flex flex-column justify-content-between w-100 min-w-0">
                                <div class="o_kanban_card_header mb-1">
                                    <strong class="o_kanban_record_title text-dark fw-bold fs-6 text-truncate d-block">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                
                                <div class="d-flex align-items-center justify-content-between small mt-1">
                                    <div class="text-danger fw-bold d-flex align-items-center">
                                        <i class="fa fa-exclamation-triangle me-1" title="Bajo Stock"/>
                                        <span>Stock: </span>
                                        <span class="ms-1"><field name="qty_available"/></span>
                                    </div>
                                    <div class="text-muted bg-200 px-2 py-0.5 rounded-pill fw-medium">
                                        <span>Obj: </span>
                                        <field name="target_stock"/>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_product_critical_stock" model="ir.actions.act_window">
        <field name="name">Productos Pendientes de Reabastecimiento</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,form</field>
        <field name="domain">[('x_is_critical', '=', True)]</field>
        <field name="context">{'group_by': 'replenishment_priority'}</field>
        <field name="view_id" ref="view_product_template_kanban_critical"/>
    </record>

    <menuitem id="menu_product_critical" 
          name="Reabastecimiento por Prioridad" 
          parent="stock.menu_stock_inventory_control" 
          action="action_product_critical_stock" 
          sequence="100"/>

</odoo>